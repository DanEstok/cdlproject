generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CASE_MANAGER
  COMPLIANCE
  WORKFORCE
  BILLING
  AUDITOR
}

enum PersonType {
  CLIENT
  CONTACT
  PARTNER_CONTACT
}

enum CaseStatus {
  OPEN
  PAUSED
  CLOSED
}

enum ProgramType {
  CCM
  SOBER_COACHING
  SAP
  DBE_PATHWAY
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum NoteType {
  CASE_NOTE
  COACHING_NOTE
  COMPLIANCE_NOTE
}

enum NoteStatus {
  DRAFT
  SIGNED
}

enum DocumentType {
  ID
  DOT_MEDICAL
  MVR
  CLEARINGHOUSE
  COURT
  HOUSING
  EMPLOYMENT
  OTHER
}

enum VerificationType {
  DOT_MEDICAL
  MVR
  CLEARINGHOUSE
}

enum VerificationStatus {
  PENDING
  PASSED
  FAILED
  UNKNOWN
}

enum WorkType {
  INTAKE
  CASE_MGMT
  COMPLIANCE
  WORKFORCE
  ADMIN_MODULES
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  users     User[]
  people    Person[]
  cases     Case[]
  notes     Note[]
  tasks     Task[]
  documents Document[]
  audits    AuditEvent[]
  invoices  Invoice[]
  time      TimeEntry[]
  verifs    Verification[]
}

model User {
  id             String   @id @default(uuid())
  organizationId String
  clerkUserId    String   @unique
  role           UserRole @default(CASE_MANAGER)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
}

model Person {
  id             String     @id @default(uuid())
  organizationId String
  type           PersonType @default(CLIENT)

  firstName      String
  lastName       String
  phone          String?
  email          String?
  dob            DateTime?
  address1       String?
  address2       String?
  city           String?
  state          String?
  postalCode     String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  cases          Case[]        @relation("ClientCases")
}

model Case {
  id             String     @id @default(uuid())
  organizationId String
  clientPersonId String
  status         CaseStatus @default(OPEN)
  openedAt       DateTime   @default(now())
  closedAt       DateTime?
  notes          String?

  primaryCaseManagerUserId String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  client         Person       @relation("ClientCases", fields: [clientPersonId], references: [id])
  enrollments    ProgramEnrollment[]
  tasks          Task[]
  notesList      Note[]
  documents      Document[]
  verifications  Verification[]
  timeEntries    TimeEntry[]
  invoices       Invoice[]

  @@index([organizationId, status])
}

model ProgramEnrollment {
  id             String           @id @default(uuid())
  organizationId String
  caseId         String
  programType    ProgramType
  status         EnrollmentStatus @default(ACTIVE)
  startedAt      DateTime         @default(now())
  endedAt        DateTime?

  organization   Organization @relation(fields: [organizationId], references: [id])
  case           Case         @relation(fields: [caseId], references: [id])

  @@index([organizationId, caseId])
}

model Task {
  id             String     @id @default(uuid())
  organizationId String
  caseId         String

  assignedToUserId   String?
  assignedToPersonId String?

  title          String
  description    String?
  status         TaskStatus @default(TODO)
  dueAt          DateTime?
  completedAt    DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  case           Case         @relation(fields: [caseId], references: [id])

  @@index([organizationId, status, dueAt])
}

model Note {
  id             String     @id @default(uuid())
  organizationId String
  caseId         String
  authorUserId   String

  noteType       NoteType
  templateKey    String?
  contentJson    Json
  narrative      String?
  status         NoteStatus @default(DRAFT)
  signedAt       DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  case           Case         @relation(fields: [caseId], references: [id])

  @@index([organizationId, caseId, createdAt])
}

model Document {
  id             String       @id @default(uuid())
  organizationId String
  caseId         String?
  personId       String?

  uploadedByUserId   String?
  uploadedByPersonId String?

  fileName       String
  mimeType       String
  storageKey     String
  sizeBytes      Int

  docType        DocumentType
  issueDate      DateTime?
  expiresAt      DateTime?

  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, expiresAt])
}

model Verification {
  id             String             @id @default(uuid())
  organizationId String
  caseId         String

  type           VerificationType
  status         VerificationStatus @default(PENDING)

  verifiedAt     DateTime?
  nextDueAt      DateTime?
  verifiedByUserId String?
  notes          String?
  evidenceDocumentId String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  case           Case         @relation(fields: [caseId], references: [id])

  @@index([organizationId, caseId, type])
}

model TimeEntry {
  id             String   @id @default(uuid())
  organizationId String
  caseId         String
  userId         String

  minutes        Int
  workType       WorkType
  performedAt    DateTime @default(now())
  notes          String?

  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id])
  case           Case         @relation(fields: [caseId], references: [id])
}

model Invoice {
  id             String        @id @default(uuid())
  organizationId String
  caseId         String?
  clientPersonId String?

  stripeInvoiceId String
  status         InvoiceStatus @default(DRAFT)
  amountCents    Int
  currency       String @default("usd")
  hostedInvoiceUrl String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  case           Case?        @relation(fields: [caseId], references: [id])
}

model AuditEvent {
  id             String   @id @default(uuid())
  organizationId String

  actorUserId      String?
  actorClerkUserId String?

  action        String
  entityType    String
  entityId      String
  diffJson      Json?

  createdAt     DateTime @default(now())

  organization  Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt])
}
