# General
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recovery_platform

# Redis
REDIS_URL=redis://localhost:6379

# Clerk (Auth)
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_JWKS_URL=https://clerk.example/.well-known/jwks.json

# Twilio
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Storage (S3/R2)
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=recovery-platform-dev
S3_ACCESS_KEY_ID=xxx
S3_SECRET_ACCESS_KEY=xxx

# DocuSign
DOCUSIGN_INTEGRATION_KEY=xxx
DOCUSIGN_USER_ID=xxx
DOCUSIGN_ACCOUNT_ID=xxx
DOCUSIGN_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
